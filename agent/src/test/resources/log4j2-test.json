{
  "configuration": {
    "status": "WARN",
    "name": "Agent-Test",
    "appenders": {
      "Console": {
        "name": "ConsoleAppender",
        "target": "SYSTEM_OUT",
        "PatternLayout": {
          "pattern": "%d{ISO8601} [%t] %-5level %logger{36} - %msg%n"
        }
      }
    },
    "loggers": {
      "root": {
        "level": "info",
        "AppenderRef": {
          "ref": "ConsoleAppender"
        }
      },
      "logger": [
        {
          "name": "com.biblocat",
          "level": "debug",
          "additivity": true,
          "AppenderRef": {
            "ref": "ConsoleAppender"
          }
        }
      ]
    }
  }
}
